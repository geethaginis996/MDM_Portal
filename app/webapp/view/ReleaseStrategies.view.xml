<?xml version="1.0" encoding="UTF-8"?>
<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    controllerName="mdm.portal.controller.ReleaseStrategies"
    displayBlock="true">

    <f:DynamicPage id="releaseStrategiesPage" fitContent="true"
        toggleHeaderOnTitleClick="false" headerExpanded="true" preserveHeaderStateOnScroll="false"
        class="sapUiSizeCondensed sapMDMFieldMasterPage">

        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <VBox>
                        <Title text="Release Strategies" level="H2" wrapping="false"/>
                    </VBox>
                </f:heading>
                <f:snappedHeading>
                    <Title text="Release Strategies" level="H3" wrapping="false"/>
                </f:snappedHeading>
                <f:actions>
                    <OverflowToolbar style="Clear">
                        <Button id="exportBtn" text="Export" icon="sap-icon://download"
                                type="Transparent" press=".onExport">
                            <layoutData><OverflowToolbarLayoutData priority="Low"/></layoutData>
                        </Button>
                        <Button id="addBtn" text="Add Strategy" icon="sap-icon://add"
                                type="Emphasized" press=".onAdd">
                            <layoutData><OverflowToolbarLayoutData priority="NeverOverflow"/></layoutData>
                        </Button>
                    </OverflowToolbar>
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="false" backgroundDesign="Translucent">
                <VBox>
                    
                    <l:Grid defaultSpan="XL3 L3 M6 S12" hSpacing="1" vSpacing="0.5"
                            class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">
                        <l:content>
                            <VBox>
                                <Label text="Strategy ID / Description" labelFor="filterSearch" design="Bold"/>
                                <Input id="filterSearch" placeholder="Search…" showClearIcon="true"
                                       width="100%" liveChange=".onFilterLiveChange"/>
                            </VBox>
                        </l:content>
                        <l:content>
                            <VBox>
                                <Label text="Applies To" labelFor="filterAppliesTo" design="Bold"/>
                                <Select id="filterAppliesTo" width="100%" change=".onFilterChange" forceSelection="false"
                                        items="{lookups>/appliesTo}">
                                    <core:Item key="{lookups>key}" text="{lookups>text}"/>
                                </Select>
                            </VBox>
                        </l:content>
                        <l:content>
                            <VBox>
                                <Label text="Status" labelFor="filterStatus" design="Bold"/>
                                <Select id="filterStatus" width="100%" change=".onFilterChange" forceSelection="false">
                                    <core:Item key="" text="All"/>
                                    <core:Item key="true" text="Active"/>
                                    <core:Item key="false" text="Inactive"/>
                                </Select>
                            </VBox>
                        </l:content>
                    </l:Grid>
                    <Toolbar style="Clear" class="sapUiSmallMarginTop">
                        <ToolbarSpacer/>
                        <Button text="Clear" type="Transparent" press=".onClearFilters"/>
                        <Button text="Go" type="Emphasized" press=".onGo"/>
                    </Toolbar>
                </VBox>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <VBox>
                <Table id="strategiesTable"
                    items="{
                        path: '/ReleaseStrategies',
                        parameters: {
                            $count: true,
                            $select: 'strategy_id,description,active,master_data_type_master_data_type_id',
                            $expand: 'values($select=operator,value_from,value_to,characteristic_characteristic_id),steps($select=step_number)',
                            $orderby: 'priority asc'
                        }
                    }"
                    growing="true" growingThreshold="50" growingScrollToLoad="true"
                    noDataText="No release strategies found"
                    mode="MultiSelect" fixedLayout="true" alternateRowColors="true"
                    sticky="ColumnHeaders,HeaderToolbar"
                    selectionChange=".onSelectionChange"
                    class="sapMDMFormalTable">

                    <headerToolbar>
                        <OverflowToolbar id="tableToolbar" style="Clear">
                            <Title id="tableTitle" text="Release Strategies" level="H3"/>
                            <ToolbarSpacer/>
                            <Button id="bulkDeleteBtn" text="Delete" icon="sap-icon://delete"
                                    type="Negative" visible="false" press=".onBulkDelete">
                                <layoutData><OverflowToolbarLayoutData priority="NeverOverflow"/></layoutData>
                            </Button>
                            <ToolbarSeparator id="bulkSeparator" visible="false"/>
                        </OverflowToolbar>
                    </headerToolbar>

                    <columns>
                        <Column id="colId"       width="7rem"  vAlign="Middle" importance="High">
                            <Label text="Strategy ID" design="Bold"/></Column>
                        <Column id="colDesc"     vAlign="Middle" importance="High">
                            <Label text="Description" design="Bold"/></Column>
                        <Column id="colApplies"  width="9rem" vAlign="Middle" importance="High">
                            <Label text="Applies To" design="Bold"/></Column>
                        <Column id="colCombo"    width="16rem" vAlign="Middle" importance="Medium">
                            <Label text="Criteria Combination" design="Bold"/></Column>
                        <Column id="colCodes"    width="7rem"  vAlign="Middle" hAlign="Center" importance="Medium">
                            <Label text="Release Codes" design="Bold"/></Column>
                        <Column id="colStatus"   width="6rem"  vAlign="Middle" hAlign="Center" importance="High">
                            <Label text="Status" design="Bold"/></Column>
                    </columns>

                    <items>
                        <ColumnListItem type="Active" press=".onRowPress">
                            <cells>
                                <Link text="{strategy_id}" press=".onLinkPress" wrapping="false"/>
                                <Text text="{description}" wrapping="false"/>
                                <ObjectIdentifier text="{= ${master_data_type_master_data_type_id} === 'BUSINESS PARTNER' ? 'Business Partner' : ${master_data_type_master_data_type_id} }"/>
                                <Text text="{path: 'strategy_id', formatter: '.formatCriteriaCombination'}" wrapping="false"/>
                                <ObjectStatus text="{path: 'strategy_id', formatter: '.formatReleaseCodesCount'}" state="None"/>
                                <ObjectStatus
                                    text="{= ${active} ? 'Active' : 'Inactive'}"
                                    state="{= ${active} ? 'Success' : 'Error'}"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </f:content>
    </f:DynamicPage>
</mvc:View>