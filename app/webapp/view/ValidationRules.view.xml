<?xml version="1.0" encoding="UTF-8"?>
<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    controllerName="mdm.portal.controller.ValidationRules"
    displayBlock="true">

    <f:DynamicPage id="validationRulesPage" fitContent="true"
        toggleHeaderOnTitleClick="false" headerExpanded="true" preserveHeaderStateOnScroll="false"
        class="sapUiSizeCondensed sapMDMFieldMasterPage">

        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <VBox>
                        <Title text="Validation Rules" level="H2" wrapping="false"/>
                        <HBox class="sapUiTinyMarginTop">
                            <ObjectStatus id="countTotal" text="{ui>/totalCount} rules"
                                          state="Information"/>
                        </HBox>
                    </VBox>
                </f:heading>
                <f:snappedHeading>
                    <Title text="Validation Rules" level="H3" wrapping="false"/>
                </f:snappedHeading>
                <f:actions>
                    <OverflowToolbar style="Clear">
                        <Button id="exportBtn" text="Export" icon="sap-icon://download"
                                type="Transparent" press=".onExport">
                            <layoutData><OverflowToolbarLayoutData priority="Low" overflowText="Export"/></layoutData>
                        </Button>
                        <Button id="addBtn" text="New Validation" icon="sap-icon://add"
                                type="Emphasized" press=".onAdd">
                            <layoutData><OverflowToolbarLayoutData priority="NeverOverflow"/></layoutData>
                        </Button>
                    </OverflowToolbar>
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="false" backgroundDesign="Translucent">
                <VBox>
                <l:Grid defaultSpan="XL3 L3 M6 S12" hSpacing="1" vSpacing="0.5"
                        class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">
                    <l:content>
                        <VBox>
                            <Label text="Validation Name / Function Name" labelFor="filterSearch" design="Bold"/>
                            <Input id="filterSearch" placeholder="Search…" showClearIcon="true"
                                   width="100%" liveChange=".onFilterLiveChange"/>
                        </VBox>
                    </l:content>
                    <l:content>
                        <VBox>
                            <Label text="Used By Fields" labelFor="filterUsage" design="Bold"/>
                            <Select id="filterUsage" width="100%" change=".onFilterChange" forceSelection="false">
                                <core:Item key="" text="All"/>
                                <core:Item key="INUSE" text="In use"/>
                                <core:Item key="NOTLINKED" text="Not linked"/>
                            </Select>
                        </VBox>
                    </l:content>
                    <l:content>
                        <VBox>
                            <Label text="Trigger" labelFor="filterTrigger" design="Bold"/>
                            <Select id="filterTrigger" width="100%" change=".onFilterChange" forceSelection="false">
                                <core:Item key="" text="All"/>
                                <core:Item key="FIELD" text="On Field Change"/>
                                <core:Item key="SAVE" text="On Save"/>
                            </Select>
                        </VBox>
                    </l:content>
                </l:Grid>
                    <Toolbar style="Clear" class="sapUiSmallMarginTop">
                        <ToolbarSpacer/>
                        <Button text="Clear" type="Transparent" press=".onClearFilters"/>
                        <Button text="Go" type="Emphasized" press=".onGo"/>
                    </Toolbar>
                </VBox>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <VBox>
                <MessageStrip id="pageMessageStrip" text="" type="Information"
                              showCloseButton="true" visible="false"
                              class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiSmallMarginTop"/>

                <Table id="ruleTable"
                    items="{
                        path: '/ValidationRules',
                        parameters: {
                            $count: true,
                            $select: 'validation_id,description,function_name,input_param_1,input_param_2,input_param_3,trigger_on,error_message',
                            $orderby: 'validation_id asc'
                        }
                    }"
                    growing="true" growingThreshold="50" growingScrollToLoad="true"
                    noDataText="No validation rules found"
                    mode="MultiSelect" fixedLayout="true" alternateRowColors="true"
                    sticky="ColumnHeaders,HeaderToolbar"
                    selectionChange=".onSelectionChange"
                    class="sapMDMFormalTable">

                    <headerToolbar>
                        <OverflowToolbar id="tableToolbar" style="Clear">
                            <Title id="tableTitle" text="Validation Rules" level="H3"/>
                            <ToolbarSpacer/>
                            <Button id="bulkDeleteBtn" text="Delete" icon="sap-icon://delete"
                                    type="Negative" visible="false" press=".onBulkDelete">
                                <layoutData><OverflowToolbarLayoutData priority="NeverOverflow"/></layoutData>
                            </Button>
                            <ToolbarSeparator id="bulkSeparator" visible="false"/>
                            <Button icon="sap-icon://action-settings"
                                    type="Transparent" tooltip="Column settings"
                                    press=".onColumnSettings">
                                <layoutData>
                                    <OverflowToolbarLayoutData priority="Low"/>
                                </layoutData>
                            </Button>
                        </OverflowToolbar>
                    </headerToolbar>

                    <columns>
                        <Column id="colId"        width="9rem"  vAlign="Middle" importance="High">
                            <Label text="Validation Name" design="Bold"/></Column>
                        <Column id="colFunction"  width="11rem" vAlign="Middle" importance="High">
                            <Label text="Function Name" design="Bold"/></Column>
                        <Column id="colP1"        width="7rem"  vAlign="Middle" importance="Low">
                            <Label text="Input Param 1" design="Bold"/></Column>
                        <Column id="colP2"        width="7rem"  vAlign="Middle" importance="Low">
                            <Label text="Input Param 2" design="Bold"/></Column>
                        <Column id="colP3"        width="7rem"  vAlign="Middle" importance="Low">
                            <Label text="Input Param 3" design="Bold"/></Column>
                        <Column id="colTrigger"   width="7rem"  vAlign="Middle" hAlign="Center" importance="Medium">
                            <Label text="Trigger" design="Bold"/></Column>
                        <Column id="colLinked"    width="6rem"  vAlign="Middle" hAlign="Center" importance="Medium">
                            <Label text="Linked Fields" design="Bold"/></Column>
                        <Column id="colActions"   width="3rem"  vAlign="Middle" hAlign="End" importance="High"/>
                    </columns>

                    <items>
                        <ColumnListItem type="Active" press=".onRowPress">
                            <cells>
                                <Link text="{validation_id}" press=".onLinkPress" wrapping="false"/>
                                <ObjectIdentifier text="{function_name}"/>
                                <Text text="{= ${input_param_1} ? ${input_param_1} : '\u2014'}" wrapping="false"/>
                                <Text text="{= ${input_param_2} ? ${input_param_2} : '\u2014'}" wrapping="false"/>
                                <Text text="{= ${input_param_3} ? ${input_param_3} : '\u2014'}" wrapping="false"/>
                                <ObjectStatus
                                    text="{path: 'trigger_on', formatter: '.formatTrigger'}"
                                    state="None"/>
                                <ObjectStatus
                                    text="{parts: [{path: 'validation_id'}, {path: 'ui>/linkedCounts'}], formatter: '.formatLinked'}"
                                    state="None"/>
                                <Button icon="sap-icon://overflow" type="Transparent"
                                        tooltip="More actions" press=".onRowMenuPress"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </f:content>
    </f:DynamicPage>
</mvc:View>