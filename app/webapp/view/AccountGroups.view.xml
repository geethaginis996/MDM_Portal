<?xml version="1.0" encoding="UTF-8"?>
<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    controllerName="mdm.portal.controller.AccountGroups"
    displayBlock="true">

    <f:DynamicPage id="accountGroupsPage" fitContent="true"
        toggleHeaderOnTitleClick="false" headerExpanded="true" preserveHeaderStateOnScroll="false"
        class="sapUiSizeCondensed sapMDMFieldMasterPage">

        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <VBox>
                        <Title text="Account Groups" level="H2" wrapping="false"/>
                        <!-- <HBox class="sapUiTinyMarginTop">
                            <ObjectStatus id="countCustomer" text="{ui>/customerCount} customer"
                                          state="Information" class="sapUiTinyMarginEnd"/>
                            <ObjectStatus id="countVendor" text="{ui>/vendorCount} vendor"
                                          state="Information"/>
                        </HBox> -->
                    </VBox>
                </f:heading>
                <f:snappedHeading>
                    <Title text="Account Groups" level="H3" wrapping="false"/>
                </f:snappedHeading>
                <f:actions>
                    <OverflowToolbar style="Clear">
                        <SegmentedButton id="typeSegment" selectedKey="CUSTOMER"
                                         selectionChange=".onTypeSegmentChange">
                            <items>
                                <SegmentedButtonItem key="CUSTOMER" text="Customer"/>
                                <SegmentedButtonItem key="VENDOR"   text="Vendor"/>
                            </items>
                        </SegmentedButton>
                        <ToolbarSeparator/>
                        <Button id="exportBtn" text="Export" icon="sap-icon://download"
                                type="Transparent" press=".onExport">
                            <layoutData><OverflowToolbarLayoutData priority="Low" overflowText="Export"/></layoutData>
                        </Button>
                        <Button id="addBtn" text="New Account Group" icon="sap-icon://add"
                                type="Emphasized" press=".onAdd">
                            <layoutData><OverflowToolbarLayoutData priority="NeverOverflow"/></layoutData>
                        </Button>
                    </OverflowToolbar>
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="false" backgroundDesign="Translucent">
                <VBox>
                    <l:Grid defaultSpan="XL6 L6 M6 S12" hSpacing="1" vSpacing="0.5"
                            class="sapUiSmallMarginTopBottom">
                        <l:content>
                            <VBox>
                                <Label text="Account Group / Description" labelFor="filterSearch" design="Bold"/>
                                <Input id="filterSearch" placeholder="Search…" showClearIcon="true"
                                       width="100%" liveChange=".onFilterLiveChange"/>
                            </VBox>
                        </l:content>
                        <l:content>
                            <VBox>
                                <Label text="Status" labelFor="filterStatus" design="Bold"/>
                                <Select id="filterStatus" width="100%" change=".onFilterChange" forceSelection="false">
                                    <core:Item key="" text="All"/>
                                    <core:Item key="true" text="Active"/>
                                    <core:Item key="false" text="Inactive"/>
                                </Select>
                            </VBox>
                        </l:content>
                    </l:Grid>
                    <Toolbar style="Clear" class="sapUiSmallMarginTop">
                        <ToolbarSpacer/>
                        <Button text="Clear" type="Transparent" press=".onClearFilters"/>
                        <Button text="Go" type="Emphasized" press=".onGo"/>
                    </Toolbar>
                </VBox>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <VBox>
                <Table id="agTable"
                    items="{
                        path: '/AccountGroups',
                        parameters: {
                            $count: true,
                            $select: 'account_group_id,description,type,number_range_id,assignment_mode,one_time,active',
                            $orderby: 'account_group_id asc'
                        }
                    }"
                    growing="true" growingThreshold="50" growingScrollToLoad="true"
                    noDataText="No account groups found"
                    mode="MultiSelect" fixedLayout="true" alternateRowColors="true"
                    sticky="ColumnHeaders,HeaderToolbar"
                    selectionChange=".onSelectionChange"
                    class="sapMDMFormalTable">

                    <headerToolbar>
                        <OverflowToolbar id="tableToolbar" style="Clear">
                            <Title id="tableTitle" text="Account Groups" level="H3"/>
                            <ToolbarSpacer/>
                            <Button id="bulkActivateBtn" text="Activate" icon="sap-icon://accept"
                                    type="Success" visible="false" press=".onBulkActivate">
                                <layoutData><OverflowToolbarLayoutData priority="NeverOverflow"/></layoutData>
                            </Button>
                            <Button id="bulkDeleteBtn" text="Delete" icon="sap-icon://delete"
                                    type="Negative" visible="false" press=".onBulkDelete">
                                <layoutData><OverflowToolbarLayoutData priority="NeverOverflow"/></layoutData>
                            </Button>
                            <ToolbarSeparator id="bulkSeparator" visible="false"/>
                        </OverflowToolbar>
                    </headerToolbar>

                    <columns>
                        <Column id="colId"       width="8rem"  vAlign="Middle" importance="High">
                            <Label text="Account Group" design="Bold"/></Column>
                        <Column id="colDesc"     width="11rem" vAlign="Middle" importance="High">
                            <Label text="Description" design="Bold"/></Column>
                        <Column id="colType"     width="7rem"  vAlign="Middle" importance="Medium">
                            <Label text="Type" design="Bold"/></Column>
                        <Column id="colNumRange" width="9rem"  vAlign="Middle" importance="Medium">
                            <Label text="Number Range" design="Bold"/></Column>
                        <Column id="colFields"   width="7rem"  vAlign="Middle" hAlign="Center" importance="Low">
                            <Label text="Additional Fields" design="Bold"/></Column>
                        <Column id="colStatus"   width="6rem"  vAlign="Middle" hAlign="Center" importance="High">
                            <Label text="Status" design="Bold"/></Column>
                        <Column id="colActions"  width="3rem"  vAlign="Middle" hAlign="End" importance="High"/>
                    </columns>

                    <items>
                        <ColumnListItem type="Active" press=".onRowPress">
                            <cells>
                                <Link text="{account_group_id}" press=".onLinkPress" wrapping="false"/>
                                <Text text="{description}" wrapping="false" maxLines="1"/>
                                <ObjectStatus text="{path: 'type', formatter: '.formatType'}" state="None"/>
                                <Text text="{path: 'assignment_mode', formatter: '.formatNumberRange'}" wrapping="false"/>
                                <ObjectStatus
                                    text="{parts: [{path: 'account_group_id'}, {path: 'ui>/fieldCounts'}], formatter: '.formatCount'}"
                                    state="None"/>
                                <ObjectStatus
                                    text="{path: 'active', formatter: '.formatActiveText'}"
                                    state="{path: 'active', formatter: '.formatActiveState'}"/>
                                <Button icon="sap-icon://overflow" type="Transparent"
                                        tooltip="More actions" press=".onRowMenuPress"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </f:content>
    </f:DynamicPage>
</mvc:View>