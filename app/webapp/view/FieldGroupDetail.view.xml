<?xml version="1.0" encoding="UTF-8"?>
<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    controllerName="mdm.portal.controller.FieldGroupDetail"
    displayBlock="true">

    <Page busy="{view>/busy}" busyIndicatorDelay="0" id="detailPage" showHeader="false">

        <content>
            <!-- ── Shell-style top bar with breadcrumb ──────────────── -->
            <VBox>
                <Bar class="sapMPageHeader">
                    <contentLeft>
                        <Button icon="sap-icon://nav-back" type="Transparent" press=".onNavBack"/>
                        <Breadcrumbs id="pageBreadcrumb"
                                     separatorStyle="Slash"
                                     class="sapUiTinyMarginBegin">
                            <Link text="{i18n>breadcrumb.configuration}" press=".onNavBack"/>
                            <Link text="{i18n>breadcrumb.fieldGroups}"  press=".onNavBack"/>
                            <!-- current item rendered as plain text by control -->
                        </Breadcrumbs>
                    </contentLeft>
                </Bar>
            </VBox>

            <!-- ── Page heading ─────────────────────────────────────── -->
            <VBox class="sapUiMediumMarginBeginEnd sapUiSmallMarginTop">

                <HBox alignItems="Center">
                    <core:Icon id="groupIcon" src="{path: 'icon', mode: 'OneWay', formatter: '.formatIcon'}" size="2rem"
                               color="Default" class="sapUiSmallMarginEnd"/>
                    <VBox>
                        <Title id="pageTitle" text="" level="H2" wrapping="false"/>
                    </VBox>
                </HBox>

              
            </VBox>

            <HBox class="sapUiTinyMarginTop sapUiMediumMarginBeginEnd">
                <core:HTML content="&lt;hr style='border:none;border-top:1px solid var(--sapGroup_TitleBorderColor);margin:0 0 0.5rem 0;width:100%'/&gt;"/>
            </HBox>

            <!-- ── Icon Tab Bar ─────────────────────────────────────── -->
            <IconTabBar id="detailTabs" select=".onTabSelect" expanded="true"
                        class="sapUiResponsiveContentPadding">
                <items>

                    <!-- ── TAB 1 · General ── -->
                    <IconTabFilter text="{i18n>tab.general}" key="general" icon="sap-icon://hint">
                        <VBox class="sapUiMediumMarginBeginEnd">

                            <Title text="{i18n>fieldGroupDetail.groupDetails}" level="H4"
                                   class="sapUiSmallMarginTop sapUiSmallMarginBottom"/>

                            <l:Grid defaultSpan="L6 M6 S12" hSpacing="2">
                                <l:content>

                                    <!-- Master Data Type -->
                                    <VBox>
                                        <Label text="{i18n>lbl.masterDataType}" required="true"
                                               labelFor="selMasterDataType"/>
                                        <Select id="selMasterDataType" width="100%"
                                                change=".onFieldChange"
                                                items="{path: 'lookups>/masterDataTypes'}">
                                            <core:Item key="{lookups>key}" text="{lookups>text}"/>
                                        </Select>
                                    </VBox>

                                    <!-- Group ID -->
                                    <VBox>
                                        <Label text="{i18n>lbl.fieldGroupName}" required="true" labelFor="inGroupId"/>
                                        <Input id="inGroupId"
                                               value="{group_id}"
                                               placeholder="e.g. GRP_COCD"
                                               editable="{view>/isNew}"
                                               maxLength="20"
                                               liveChange=".onFieldChange"/>
                                    </VBox>

                                    <!-- Description -->
                                    <VBox>
                                        <Label text="{i18n>lbl.description}" required="true" labelFor="inDescription"/>
                                        <Input id="inDescription"
                                               value="{description}"
                                               placeholder="e.g. Company Code Data"
                                               maxLength="100"
                                               liveChange=".onFieldChange"/>
                                    </VBox>

                                    <!-- Icon -->
                                    <VBox>
                                        <Label text="{i18n>lbl.icon}" labelFor="inIcon"/>
                                        <HBox alignItems="Center">
                                            <core:Icon id="iconPreview" src="{path: 'icon', mode: 'OneWay', formatter: '.formatIcon'}"
                                                       size="1.5rem" color="Default"
                                                       class="sapUiSmallMarginEnd"/>
                                            <Input id="inIcon"
                                                   value="{icon}"
                                                   placeholder="sap-icon://building"
                                                   width="100%"
                                                   liveChange=".onIconLiveChange"/>
                                        </HBox>
                                    </VBox>

                                    <!-- Parent Group -->
                                    <VBox>
                                        <Label text="{i18n>filter.parentGroup}" labelFor="selParentGroup"/>
                                        <Select id="selParentGroup" width="100%"
                                                change=".onParentGroupChange"
                                                forceSelection="false"
                                                items="{path: 'lookups>/parentGroups'}">
                                            <core:Item key="{lookups>key}" text="{lookups>text}"/>
                                        </Select>
                        
                                    </VBox>

                                    <!-- Sequence -->
                                    <VBox>
                                        <Label text="{i18n>lbl.sequence}" required="true" labelFor="inSequence"/>
                                        <Input id="inSequence"
                                               value="{sequence}"
                                               type="Number"
                                               placeholder="e.g. 1"
                                               liveChange=".onFieldChange"/>
                                    </VBox>

                                </l:content>
                            </l:Grid>

                            <!-- Active switch -->
                            <HBox alignItems="Center" class="sapUiSmallMarginTop">
                                <Label text="{i18n>lbl.active}" labelFor="swActive"
                                       class="sapUiSmallMarginEnd" width="8rem"/>
                                <Switch id="swActive"
                                        state="{active}"
                                        customTextOn="Yes"
                                        customTextOff="No"
                                        change=".onFieldChange"/>
                            </HBox>

                        </VBox>
                    </IconTabFilter>

                    <!-- ── TAB 2 · Sub Groups ── -->
                    <IconTabFilter id="tabSubGroups" text="{i18n>tab.subGroups}" key="subGroups"
                                   count="{view>/subGroupCount}"
                                   icon="sap-icon://add-subfolder">
                        <VBox>
                            <Toolbar class="sapUiSmallMarginTop">
                                <Title text="{i18n>tab.subGroups}" level="H4"/>
                                <ToolbarSpacer/>
                                <Button text="{i18n>fieldGroupDetail.addSubGroup}" icon="sap-icon://add"
                                        type="Emphasized" press=".onAddSubGroup"
                                        enabled="{= !${view>/isNew}}"/>
                            </Toolbar>

                            <Table id="subGroupTable"
                                   noDataText="{= ${view>/isNew} ? 'Save the group first to add sub-groups.' : 'No sub-groups defined yet.'}"
                                   fixedLayout="true"
                                   alternateRowColors="true"
                                   items="{subGroups>/items}">
                                <columns>
                                    <Column width="7rem">
                                        <Label text="{i18n>lbl.fieldGroupName}" design="Bold"/>
                                    </Column>
                                    <Column>
                                        <Label text="{i18n>lbl.description}" design="Bold"/>
                                    </Column>
                                    <Column width="4rem" hAlign="End">
                                        <Label text="{i18n>col.sequence}" design="Bold"/>
                                    </Column>
                                    <Column width="5rem" hAlign="Center">
                                        <Label text="{i18n>lbl.status}" design="Bold"/>
                                    </Column>
                                    <Column width="3rem" hAlign="End"/>
                                </columns>
                                <items>
                                    <ColumnListItem type="Active" press=".onSubGroupRowPress">
                                        <cells>
                                            <Link text="{subGroups>group_id}"
                                                  press=".onSubGroupLinkPress" wrapping="false"/>
                                            <Text text="{subGroups>description}" wrapping="false"/>
                                            <Text text="{subGroups>sequence}" wrapping="false"/>
                                            <ObjectStatus
                                                text="{= ${subGroups>active} ? 'Active' : 'Inactive'}"
                                                state="{= ${subGroups>active} ? 'Success' : 'Error'}"/>
                                            <Button icon="sap-icon://slim-arrow-right"
                                                    type="Transparent"
                                                    press=".onSubGroupRowPress"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </IconTabFilter>

                    <!-- ── TAB 3 · Assigned Fields ── -->
                    <IconTabFilter id="tabAssignedFields" text="{i18n>fieldGroupDetail.assignedFields}" key="assignedFields"
                                   count="{view>/assignedFieldCount}"
                                   icon="sap-icon://form">
                        <VBox>
                            <Toolbar class="sapUiSmallMarginTop">
                                <Title text="{i18n>fieldGroupDetail.assignedFieldsDesc}" level="H4"/>
                                <ToolbarSpacer/>
                                <Button icon="sap-icon://add"
                                        text="Assign Fields"
                                        type="Emphasized"
                                        press=".onAssignFieldsToGroup"
                                        enabled="{= !${view>/isNew} }"/>
                            </Toolbar>

                            <Table id="fieldsTable"
                                   noDataText="No fields assigned to this group yet."
                                   fixedLayout="true"
                                   alternateRowColors="true"
                                   items="{assignedFields>/items}">
                                <columns>
                                    <Column width="8rem">
                                        <Label text="{i18n>col.fieldId}" design="Bold"/>
                                    </Column>
                                    <Column>
                                        <Label text="{i18n>lbl.description}" design="Bold"/>
                                    </Column>
                                    <Column width="6rem">
                                        <Label text="{i18n>col.dataType}" design="Bold"/>
                                    </Column>
                                    <Column width="7rem">
                                        <Label text="{i18n>col.displayType}" design="Bold"/>
                                    </Column>
                                    <Column width="5rem" hAlign="Center">
                                        <Label text="{i18n>lbl.status}" design="Bold"/>
                                    </Column>
                                    <Column width="3rem" hAlign="End"/>
                                </columns>
                                <items>
                                    <ColumnListItem type="Active" press=".onFieldRowPress">
                                        <cells>
                                            <Link text="{assignedFields>field_id}"
                                                  press=".onFieldLinkPress" wrapping="false"/>
                                            <Text text="{assignedFields>description}" wrapping="false"/>
                                            <Text text="{assignedFields>data_type}"   wrapping="false"/>
                                            <Text text="{assignedFields>display_type}" wrapping="false"/>
                                            <ObjectStatus
                                                text="{= ${assignedFields>active} ? 'Active' : 'Inactive'}"
                                                state="{= ${assignedFields>active} ? 'Success' : 'Error'}"/>
                                            <Button icon="sap-icon://decline"
                                                    type="Transparent"
                                                    tooltip="Remove from group"
                                                    press=".onRemoveFieldFromGroup"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </IconTabFilter>

                    <!-- ── TAB 4 · Change Log ── -->
                                        <IconTabFilter text="{i18n>tab.changeLog}" key="changelog" icon="sap-icon://history">
                        <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop sapUiSmallMarginBottom">
                            <Title text="{i18n>lbl.recordInfo}" level="H5" class="sapUiTinyMarginBottom"/>
                            <HBox wrap="Wrap">
                                <VBox width="12rem" class="sapUiTinyMarginEnd">
                                    <Label text="{i18n>lbl.createdOn}" design="Bold"/>
                                    <Text id="clCreatedAt" text="{view>/clCreatedAt}" wrapping="false"/>
                                </VBox>
                                <VBox width="12rem" class="sapUiTinyMarginEnd">
                                    <Label text="{i18n>lbl.createdBy}" design="Bold"/>
                                    <Text id="clCreatedBy" text="{view>/clCreatedBy}" wrapping="false"/>
                                </VBox>
                                <VBox width="12rem" class="sapUiTinyMarginEnd">
                                    <Label text="{i18n>lbl.modifiedOn}" design="Bold"/>
                                    <Text id="clModifiedAt" text="{view>/clModifiedAt}" wrapping="false"/>
                                </VBox>
                                <VBox width="12rem">
                                    <Label text="{i18n>lbl.modifiedBy}" design="Bold"/>
                                    <Text id="clModifiedBy" text="{view>/clModifiedBy}" wrapping="false"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <Table id="logTable"
                               noDataText="No changes recorded yet."
                               alternateRowColors="true"
                               items="{path: '/AuditLogs', suspended: true}">
                            <columns>
                                <Column width="11rem"><Label text="{i18n>col.timestamp}" design="Bold"/></Column>
                                <Column width="9rem"><Label text="{i18n>col.user}" design="Bold"/></Column>
                                <Column width="7rem"><Label text="{i18n>col.action}" design="Bold"/></Column>
                                <Column><Label text="{i18n>lbl.triggerBefore}" design="Bold"/></Column>
                                <Column><Label text="{i18n>lbl.triggerAfter}" design="Bold"/></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{acted_at}" wrapping="false"/>
                                        <Text text="{actor}"    wrapping="false"/>
                                        <ObjectStatus
                                            text="{action}"
                                            state="{= ${action} === 'CREATE' ? 'Success' :
                                                   ${action} === 'DELETE' ? 'Error'   :
                                                   ${action} === 'UPDATE' ? 'Warning' : 'None'}"/>
                                        <Text text="{before_value}" maxLines="3"/>
                                        <Text text="{after_value}"  maxLines="3"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </IconTabFilter>

                </items>
            </IconTabBar>
        </content>

        <footer>
            <OverflowToolbar>
                <ToolbarSpacer/>
                <Button id="btnCopy"   text="{i18n>btn.copy}"   icon="sap-icon://copy"
                        type="Transparent" press=".onCopy"/>
                <Button id="btnCancel" text="{i18n>btn.cancel}" type="Default" press=".onCancel"/>
                <Button id="btnSave"   text="{i18n>btn.save}"   type="Emphasized" press=".onSave"/>
            </OverflowToolbar>
        </footer>

    </Page>
</mvc:View>