<?xml version="1.0" encoding="UTF-8"?>
<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form">

    <Dialog id="addSubGroupDialog"
            title="Add Sub-Group"
            contentWidth="28rem"
            draggable="true"
            resizable="false">

        <content>
            <VBox class="sapUiSmallMargin">

                <!-- Parent Group (read-only — pre-set from current main group) -->
                <f:SimpleForm editable="false" layout="ResponsiveGridLayout"
                              labelSpanL="4" labelSpanM="4" labelSpanS="4"
                              emptySpanL="0" emptySpanM="0" emptySpanS="0"
                              columnsL="1" columnsM="1">
                    <f:content>
                        <Label text="Parent Group"/>
                        <Text id="subDlgParentLabel" text=""/>

                        <Label text="Group ID" required="true"/>
                        <Input id="subDlgGroupId"
                               width="100%"
                               maxLength="20"
                               placeholder="e.g. KNB1_SUB"
                               valueLiveUpdate="true"
                               liveChange=".onSubGroupIdLiveChange"/>

                        <Label text="Description" required="true"/>
                        <Input id="subDlgDescription"
                               width="100%"
                               maxLength="100"
                               placeholder="e.g. Company Code Data"/>

                        <Label text="Sequence"/>
                        <Input id="subDlgSequence"
                               width="100%"
                               type="Number"
                               value="10"
                               placeholder="10"/>

                        <Label text="Icon"/>
                        <Input id="subDlgIcon"
                               width="100%"
                               placeholder="sap-icon://group"
                               value="sap-icon://group"/>
                    </f:content>
                </f:SimpleForm>

            </VBox>
        </content>

        <beginButton>
            <Button id="subDlgSaveBtn"
                    text="Create Sub-Group"
                    type="Emphasized"
                    enabled="false"
                    press=".onSubGroupDialogSave"/>
        </beginButton>
        <endButton>
            <Button text="Cancel"
                    press=".onSubGroupDialogCancel"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>