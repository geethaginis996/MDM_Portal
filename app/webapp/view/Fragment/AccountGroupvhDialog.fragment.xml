<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">

    <Dialog id="dlgAgVH"
            title="Select Account Group"
            contentWidth="44rem"
            contentHeight="32rem"
            draggable="true"
            resizable="true"
            class="sapUiNoContentPadding">

        <subHeader>
            <Bar>
                <contentMiddle>
                    <SearchField id="agVHSearch"
                                 width="100%"
                                 placeholder="Search by ID or description..."
                                 liveChange=".onAgVHSearch"/>
                </contentMiddle>
            </Bar>
        </subHeader>

        <content>
            <Table id="agVHTable"
                   width="100%"
                   mode="SingleSelectMaster"
                   selectionChange=".onAgVHSelect"
                   noDataText="No account groups found."
                   items="{agVH>/items}">
                <columns>
                    <Column width="8rem">
                        <Label text="Account Group" design="Bold"/>
                    </Column>
                    <Column>
                        <Label text="Description" design="Bold"/>
                    </Column>
                    <Column width="8rem">
                        <Label text="Type" design="Bold"/>
                    </Column>
                    <Column width="8rem">
                        <Label text="Number Range" design="Bold"/>
                    </Column>
                </columns>
                <items>
                    <ColumnListItem type="Active" press=".onAgVHSelect">
                        <cells>
                            <Text text="{agVH>key}"        wrapping="false"/>
                            <Text text="{agVH>description}" wrapping="false"/>
                            <Text text="{agVH>type}"       wrapping="false"/>
                            <Text text="{agVH>numberRange}" wrapping="false"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>

        <endButton>
            <Button text="Cancel" press=".onAgVHCancel"/>
        </endButton>
    </Dialog>

</core:FragmentDefinition>