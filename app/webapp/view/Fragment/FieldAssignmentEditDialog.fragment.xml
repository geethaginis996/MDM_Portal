<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout">

    <Dialog id="fieldAssignmentEditDialog"
            title="Field Assignment"
            contentWidth="32rem"
            resizable="true"
            draggable="true"
            busy="{fieldEdit>/busy}">

        <content>
            <VBox class="sapUiSmallMargin">

                <!-- Field master info, for context — view only -->
                <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                    <core:Icon src="sap-icon://form" size="1.25rem" color="Default"
                               class="sapUiTinyMarginEnd"/>
                    <Title text="{fieldEdit>/field_id}" level="H4" wrapping="false"/>
                    <Text text=" \u2014 {fieldEdit>/description}" class="sapUiTinyMarginBegin" wrapping="false"/>
                </HBox>

                <l:Grid defaultSpan="L4 M4 S12" hSpacing="2" class="sapUiSmallMarginBottom">
                    <l:content>
                        <ObjectAttribute title="Data Type"    text="{fieldEdit>/data_type}"/>
                        <ObjectAttribute title="Display Type" text="{fieldEdit>/display_type}"/>
                        <ObjectAttribute title="Group"        text="{fieldEdit>/group_path}"/>
                    </l:content>
                </l:Grid>

                <core:HTML content="&lt;hr style='border:none;border-top:1px solid var(--sapGroup_TitleBorderColor);margin:0 0 0.75rem 0;width:100%'/&gt;"/>

                <!-- Editable assignment attributes -->
                <Label text="Field Status" required="true" labelFor="selAssignStatus"/>
                <Select id="selAssignStatus" width="100%" selectedKey="{fieldEdit>/field_status}">
                    <core:Item key="REQUIRED" text="Required"/>
                    <core:Item key="OPTIONAL" text="Optional"/>
                    <core:Item key="SUPPRESS" text="Suppress"/>
                </Select>

                <Label text="Sequence" required="true" labelFor="inAssignSeq"
                       class="sapUiSmallMarginTop"/>
                <Input id="inAssignSeq" type="Number" value="{fieldEdit>/sequence}" width="100%"/>

                <Label text="Default Value" labelFor="inAssignDefault"
                       class="sapUiSmallMarginTop"/>
                <Input id="inAssignDefault" value="{fieldEdit>/default_value}" width="100%"/>

                <HBox alignItems="Center" class="sapUiSmallMarginTop"
                      visible="{fieldEdit>/showReadOnly}">
                    <Label text="Read Only" class="sapUiTinyMarginEnd" width="8rem"/>
                    <Switch state="{fieldEdit>/read_only}" customTextOn="Yes" customTextOff="No"/>
                </HBox>

            </VBox>
        </content>

        <beginButton>
            <Button text="Save" type="Emphasized" press=".onFieldAssignmentSave"/>
        </beginButton>
        <endButton>
            <Button text="Cancel" press=".onFieldAssignmentCancel"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>
