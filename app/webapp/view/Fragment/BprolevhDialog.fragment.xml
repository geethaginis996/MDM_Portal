<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog id="dlgRoleVH"
            title="Select BP Roles"
            contentWidth="52rem"
            contentHeight="36rem"
            draggable="true"
            resizable="true"
            class="sapUiNoContentPadding">

        <subHeader>
            <Bar>
                <contentLeft>
                    <Text text="{= ${roleVH>/selectedCount} + ' role(s) selected'}"
                          class="sapUiSmallMarginBegin"
                          style="font-weight: 600;"/>
                </contentLeft>
                <contentMiddle>
                    <SearchField id="roleVHSearch"
                                 width="22rem"
                                 placeholder="Search by role ID or description..."
                                 liveChange=".onRoleVHSearch"/>
                </contentMiddle>
            </Bar>
        </subHeader>

        <content>
            <Table id="roleVHTable"
                   width="100%"
                   mode="MultiSelect"
                   selectionChange=".onRoleVHSelectionChange"
                   noDataText="No roles found."
                   items="{roleVH>/items}">
                <columns>
                    <Column width="8rem">
                        <Label text="Role ID" design="Bold"/>
                    </Column>
                    <Column>
                        <Label text="Description" design="Bold"/>
                    </Column>
                    <Column width="8rem" hAlign="Center">
                        <Label text="Master Data Type" design="Bold"/>
                    </Column>
                    <Column width="8rem" hAlign="Center">
                        <Label text="Has Prereqs" design="Bold"/>
                    </Column>
                </columns>
                <items>
                    <ColumnListItem selected="{roleVH>selected}" type="Active"
                                    press=".onRoleVHRowPress">
                        <cells>
                            <Text text="{roleVH>key}"  wrapping="false"/>
                            <Text text="{roleVH>description}" wrapping="false"/>
                            <Text text="{roleVH>scopeDisp}"   wrapping="false"/>
                            <core:Icon src="{= ${roleVH>hasPrereq} ? 'sap-icon://chain-link' : ''}"
                                       color="Accent5"
                                       tooltip="{= ${roleVH>hasPrereq} ? 'Has prerequisite roles' : ''}"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>

        <beginButton>
            <Button text="Confirm" type="Emphasized" press=".onRoleVHConfirm"/>
        </beginButton>
        <endButton>
            <Button text="Cancel" press=".onRoleVHCancel"/>
        </endButton>
    </Dialog>

</core:FragmentDefinition>