<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog id="dlgFieldVH"
            title="{fieldVH>/title}"
            contentWidth="44rem"
            contentHeight="32rem"
            draggable="true"
            resizable="true"
            busy="{fieldVH>/busy}"
            class="sapUiNoContentPadding">

        <subHeader>
            <Bar>
                <contentMiddle>
                    <SearchField id="fieldVHSearch"
                                 width="100%"
                                 placeholder="Search by key or description..."
                                 liveChange=".onFieldVHSearch"/>
                </contentMiddle>
            </Bar>
        </subHeader>

        <content>
            <Table id="fieldVHTable"
                   width="100%"
                   mode="None"
                   noDataText="No values found."
                   items="{fieldVH>/items}">
                <columns>
                    <Column width="10rem">
                        <Label text="Key" design="Bold"/>
                    </Column>
                    <Column>
                        <Label text="Description" design="Bold"/>
                    </Column>
                </columns>
                <items>
                    <ColumnListItem type="Active" press=".onFieldVHSelect">
                        <cells>
                            <Text text="{fieldVH>code}"  wrapping="false"/>
                            <Text text="{fieldVH>text}"  wrapping="false"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>

        <endButton>
            <Button text="Cancel" press=".onFieldVHCancel"/>
        </endButton>
    </Dialog>

</core:FragmentDefinition>